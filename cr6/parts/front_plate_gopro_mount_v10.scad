    radius > 0 && p[2] >= 1.80 && p[2] <= (1.99 + relief_height) &&
    max([for (hole = holes) (pow(p[0] - hole[0], 2) + pow(p[1] - hole[1], 2) <= pow(radius, 2)) ? 1 : 0]) > 0;
function face_center(points, face) = [
    (points[face[0]][0] + points[face[1]][0] + points[face[2]][0]) / 3,
    (points[face[0]][1] + points[face[1]][1] + points[face[2]][1]) / 3,
    (points[face[0]][2] + points[face[1]][2] + points[face[2]][2]) / 3
];
function keep_mount_face_for_relief(points, face, holes, radius, relief_height) =
    !point_in_relief_column(face_center(points, face), holes, radius, relief_height);

function mirror_plate_point(p) = [-p[0], p[1], p[2]];
function mirror_plate_face(face) = [face[0], face[2], face[1]];
function rotate_mount_point(p, angle) = [p[0] * cos(angle) - p[1] * sin(angle), p[0] * sin(angle) + p[1] * cos(angle), p[2]];

function selected_front_points(mode) = mode == 2 ? front_all_holes_points : mode == 1 ? [for (p = front_points) mirror_plate_point(p)] : front_points;
function selected_front_faces(mode) = mode == 2 ? front_all_holes_faces : mode == 1 ? [for (face = front_faces) mirror_plate_face(face)] : front_faces;

module front_plate_gopro_mount_v10(
    mount_rotation = mount_rotation_degrees,
    hole_mode = plate_hole_mode,
    relief_diameter = screw_access_relief_diameter,
    relief_height = screw_access_relief_height
) {
    plate_points = selected_front_points(hole_mode);
    plate_faces = selected_front_faces(hole_mode);
    plate_point_count = len(plate_points);
    holes = selected_hole_centers(hole_mode);
    radius = relief_radius(relief_diameter);
    rotated_gopro_points = [for (p = gopro_points) rotate_mount_point(p, mount_rotation)];

    // Keep the base plate untouched. Relief only removes low GoPro-mount faces inside the screw-head circles.
    relieved_gopro_faces = [
        for (face = gopro_faces)
            if (keep_mount_face_for_relief(rotated_gopro_points, face, holes, radius, relief_height))
                [face[0] + plate_point_count, face[1] + plate_point_count, face[2] + plate_point_count]
    ];

    polyhedron(
        points = concat(plate_points, rotated_gopro_points),
        faces = concat(plate_faces, relieved_gopro_faces),
        convexity = 10
    );
}

front_plate_gopro_mount_v10();
