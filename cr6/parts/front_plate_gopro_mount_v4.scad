function rotate_mount_point(p, angle) = [
    p[0] * cos(angle) - p[1] * sin(angle),
    p[0] * sin(angle) + p[1] * cos(angle),
    p[2]
];

module front_plate_gopro_mount_v4(mount_rotation = mount_rotation_degrees) {
    front_point_count = len(front_points);
    polyhedron(
        points = concat(
            front_points,
            [for (p = gopro_points) rotate_mount_point(p, mount_rotation)]
        ),
        faces = concat(
            front_faces,
            [for (face = gopro_faces) [face[0] + front_point_count, face[1] + front_point_count, face[2] + front_point_count]]
        ),
        convexity = 10
    );
}

